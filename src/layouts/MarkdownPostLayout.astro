---
// When you include the layout frontmatter property in an .md file,
// all of your frontmatter YAML values are available to the layout file.
const { frontmatter } = Astro.props;
---

<meta charset="utf-8" />
<h1>{frontmatter.title}</h1>
<p>Published on: {frontmatter.pubDate.toString().slice(0, 10)}</p>
<p>Written by {frontmatter.author}</p>
<p>Tags</p>
<ul>
    <li>{frontmatter.tags.toString()}</li>
</ul>
<slot />
