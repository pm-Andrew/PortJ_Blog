---
// import global CSS
import "../styles/global.css";
// import Navi Component
import Header from "../components/Header.astro";
// import Footer Component
import Footer from "../components/Footer.astro";

// page title
const pageTitle = "About Me";

// metadata - JS expressions
const identity = {
    firstName: "Andrew",
    country: "US",
    occupation: "Tutor/ Student",
    hobbies: ["Cooking", "Disc Golf", "Anime", "Fishing"],
};

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Writing Docs"];

// conditional rendering elements
const happy = true;
const finished = false;
const goal = 3;

// CSS Variable
const skillColor = "crimson";
const fontWeight = "bold";
const textCase = "uppercase";
---

<style define:vars={{ skillColor, fontWeight, textCase }}>
    h1 {
        color: purple;
        font-size: 4rem;
    }
    .skill {
        color: var(--skillColor);
        font-weight: var(--fontWeight);
        text-transform: var(--textCase);
    }
</style>

<h1>PortJourney - {pageTitle}</h1>

<!-- 
- Header using Custom HTML Elements
- Updated from using Route style links
-->
<Header />

<p>Here are a few facts about me:</p>
<ul>
    <li>My name is {identity.firstName}.</li>
    <li>
        I live in {identity.country} and I work as a {identity.occupation}.
    </li>
    {
        identity.hobbies.length >= 2 && (
            <li>
                Two of my hobbies are: {identity.hobbies[0]} and{" "}
                {identity.hobbies[1]}
            </li>
        )
    }
</ul>
<p>My skills are:</p>
<ul>
    {skills.map((skill) => <li class="skill">{skill}</li>)}
</ul>
<h2>Rendering Elements</h2>
{happy && <p>I am happy to be learning Astro!</p>}
{finished && <p>I finished this tutorial!</p>}
{
    goal === 3 ? (
        <p>My goal is to finish in 3 days</p>
    ) : (
        <p>My goal is not 3 days</p>
    )
}
<Footer />
