---
// import global CSS
import "../styles/global.css";
// using a BaseLayout for Reusable layout
import BaseLayout from "../layouts/BaseLayout.astro";

// page title
const pageTitle = "About Me";

// CSS Variable
const skillColor = "crimson";
const fontWeight = "bold";
const textCase = "uppercase";
---

<!-- This is using the CSS variables above to style .skill -->
<style define:vars={{ skillColor, fontWeight, textCase }}>
    .skill {
        color: var(--skillColor);
        font-weight: var(--fontWeight);
        text-transform: var(--textCase);
    }
</style>

<BaseLayout pageTitle={pageTitle}>
    <h2>Portfolio + Journey = <span class="logo">PortJourney</span></h2>
    <p>
        My attempt to link my experience from my time as a Ironworker Apprentice
        & running Milling equipment, and mixing it with the journey from my
        experience into Web Development, Computer Science, and being a student
        during the AI era.
    </p>
</BaseLayout>

